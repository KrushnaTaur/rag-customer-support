# ──────────────────────────────────────────────────────
# .env — Copy this to .env and fill in your values
# NEVER commit the real .env to GitHub
# ──────────────────────────────────────────────────────

# LLM Provider (get free key at https://aistudio.google.com)
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Alternatively use OpenAI
# OPENAI_API_KEY=your_openai_api_key_here

# Vector Store
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=customer_support_kb

# Embedding Model (runs locally, no API key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chunking Config
CHUNK_SIZE=500
CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=4

# RAG Confidence Threshold (below this → HITL escalation)
CONFIDENCE_THRESHOLD=0.60

# HITL Database
HITL_DB_URL=sqlite:///./data/hitl_queue.db

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
